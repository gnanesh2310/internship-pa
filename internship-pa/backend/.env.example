# ── Supabase ──────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── AI Providers (free tiers) ──────────────────
GEMINI_API_KEY=your_gemini_api_key          # Primary: aistudio.google.com
GROQ_API_KEY=your_groq_api_key              # Backup 1: console.groq.com
OPENROUTER_API_KEY=your_openrouter_key      # Backup 2: openrouter.ai
TOGETHER_API_KEY=your_together_key          # Backup 3: api.together.xyz

# ── Gmail OAuth ────────────────────────────────
GMAIL_CLIENT_ID=your_oauth_client_id
GMAIL_CLIENT_SECRET=your_oauth_client_secret
GMAIL_COMPANY_REFRESH_TOKEN=refresh_token_for_kgnanesh98
GMAIL_RESEARCH_REFRESH_TOKEN=refresh_token_for_kgnanesh52

# ── Telegram ───────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token           # From @BotFather
TELEGRAM_CHAT_ID=8394802242                 # Your personal chat ID

# ── Google Sheets ──────────────────────────────
GOOGLE_SHEETS_ID=your_spreadsheet_id
GOOGLE_SHEETS_CREDENTIALS_JSON=path/to/service_account.json

